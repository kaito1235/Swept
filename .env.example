# App
NODE_ENV=development
APP_NAME=Swept

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/swept_dev

# Supabase (server-side — use service role key, NEVER anon key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client (Vite exposes VITE_ prefix to browser — use anon key only)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=http://localhost:3001/api

# Stripe (server-side — secret key, never exposed to browser)
STRIPE_SECRET_KEY=sk_test_...

# Stripe (client-side — publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase Storage bucket for booking confirmation photos
VITE_SUPABASE_PHOTOS_BUCKET=booking-confirmations
